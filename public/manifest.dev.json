{
  "manifest_version": 3,
  "name": "Gastly",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://localhost/*", "https://gastly-extension-api.tools/*"]
}
